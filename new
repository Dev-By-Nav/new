useEffect(() => {
  async function loadImage() {
    try {
      const response = await fetch(
        `https://api.unsplash.com/photos/random?query=${title || "study"}&client_id=YOUR_KEY`
      );

      const data = await response.json();

      if (data.urls && data.urls.small) {
        setThumbUrl(data.urls.small);
      }
    } catch (error) {
      // Fail silently
    }
  }

  loadImage();
}, [title]);